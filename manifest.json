{
  "manifest_version": 3,
  "name": "paperboy",
  "version": "1.0.0",
  "description": "Minimal RSS reader as new tab",
  "browser_specific_settings": {
    "gecko": {
      "id": "paperboy@paperboy.dev",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "nativeMessaging",
    "alarms"
  ],
  "host_permissions": ["<all_urls>"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "background": {
    "service_worker": "background.js",
    "scripts": ["storage.js", "background.js"]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; img-src * data: blob:; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["reader.html", "theme.js", "fonts/*"],
      "matches": ["<all_urls>"]
    }
  ]
}